# SILS — Neon Postgres + Clerk
# Copy to .env and fill in values.
#
# Neon: https://neon.tech — Connection string (pooled) and direct URL for migrations.
# Clerk: https://dashboard.clerk.com — Publishable key (frontend) and Secret key (backend).

# ----- Database (Neon Postgres) -----
# Pooled connection for app runtime (use with ?pgbouncer=true if using PgBouncer)
DATABASE_URL="postgresql://[user]:[password]@[neon-hostname]/[dbname]?sslmode=require"

# Direct connection for Prisma migrations / schema push (no pooling)
DIRECT_URL="postgresql://[user]:[password]@[neon-hostname]/[dbname]?sslmode=require"

# ----- Clerk (Auth) -----
# From Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
