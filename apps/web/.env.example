# SILS Web — Next.js 15
# Copy to .env.local for local development.
#
# Database: use same Neon Postgres URLs as root .env (or override per app).
# Clerk: required for auth; get keys from https://dashboard.clerk.com

# ----- Database (Neon Postgres) -----
# DATABASE_URL="postgresql://[user]:[password]@[neon-hostname]/[dbname]?sslmode=require"
# DIRECT_URL="postgresql://[user]:[password]@[neon-hostname]/[dbname]?sslmode=require"
DATABASE_URL="postgresql://neondb_owner:npg_h6uXdYk8KwNB@ep-cold-moon-aiw5w6dc-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://neondb_owner:npg_h6uXdYk8KwNB@ep-cold-moon-aiw5w6dc-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# ----- Clerk -----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ZGlzdGluY3Qtb3Jpb2xlLTk2LmNsZXJrLmFjY291bnRzLmRldiQ
CLERK_SECRET_KEY=sk_test_Ukb71LnQIOpqzjRNUL6PC1W7TR4UOt671K3PvohjBA
# Optional: after sign-in redirect (defaults to /auth/callback)
# CLERK_AFTER_SIGN_IN_URL=/auth/callback
# Force redirects (no Clerk org selection page): sign-in → /auth/callback, sign-up → /onboarding
# NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/auth/callback
# NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding
# Super Admin: who can access /admin. Use either or both:
# - SUPER_ADMIN_CLERK_USER_IDS: comma-separated Clerk user IDs (e.g. user_xxx)
# - SUPER_ADMIN_EMAILS: comma-separated emails (matched to signed-in user's primary email)
# SUPER_ADMIN_CLERK_USER_IDS=user_xxx,user_yyy
# SUPER_ADMIN_EMAILS=admin@example.com
# Seed (for pnpm db:seed): platform owner. Optional after deleting yourself from Clerk — seed can create the user.
# SEED_PLATFORM_OWNER_CLERK_USER_ID=user_xxx
# SEED_PLATFORM_OWNER_EMAIL=jerevick83@proton.me
# SEED_PLATFORM_OWNER_USERNAME=Jerevick
# SEED_PLATFORM_OWNER_FIRST_NAME=Jeremiah Victor
# SEED_PLATFORM_OWNER_LAST_NAME=Harding

# ----- App URL (for welcome email and Clerk redirect) -----
# NEXT_PUBLIC_APP_URL=https://app.sils.app
# For slug-based dashboard URL in welcome email, e.g. https://[slug].sils.app
# NEXT_PUBLIC_APP_DOMAIN=sils.app

# ----- PWA (optional) -----
# Set PWA_DISABLED=true to disable PWA (e.g. in dev if service worker gets in the way)
# PWA_DISABLED=true

# ----- AI (AutoBuild course from syllabus) -----
# ANTHROPIC_API_KEY=sk-ant-xxx  # From https://console.anthropic.com

# ----- Email (Resend) - optional; welcome email when onboarding is approved -----
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=SILS <onboarding@yourdomain.com>

# ----- Stripe (online payments: card, PayPal, Google Pay, etc.) -----
# Create an account at https://dashboard.stripe.com and enable the payment methods you want.
# STRIPE_SECRET_KEY=sk_live_xxx  (or sk_test_xxx for test mode)
# STRIPE_WEBHOOK_SECRET=whsec_xxx
#
# Webhook URL in Dashboard must be publicly accessible (e.g. https://yourdomain.com/api/webhooks/stripe).
# For local testing: run "stripe listen --forward-to localhost:3000/api/webhooks/stripe" and use the
# signing secret it prints (whsec_...) as STRIPE_WEBHOOK_SECRET in .env.local.
