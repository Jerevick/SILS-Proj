// Prisma schema for SILS — Student Information and Learning System
// Database: Neon Postgres with full PGVector extension (vector search)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ----- Extensions (PGVector) -----
// Enable in Neon: CREATE EXTENSION IF NOT EXISTS vector;
// vector(1536) matches OpenAI text-embedding-ada-002 / compatible embeddings.

// ----- Enums -----
enum UserRole {
  OWNER
  ADMIN
  INSTRUCTOR
  LEARNER
  SUPPORT
}

enum DeploymentMode {
  SIS
  LMS
  HYBRID
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

// Onboarding: deployment mode choice during request (SIS, LMS, Hybrid SIS+LMS)
enum OnboardingDeploymentMode {
  SIS
  LMS
  HYBRID
}

enum OnboardingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Platform (super admin) staff roles — who can do what on the admin side
enum PlatformRole {
  PLATFORM_OWNER       // Full control: staff, institutions, onboarding
  PLATFORM_ADMIN       // Institutions + onboarding; cannot manage staff
  ONBOARDING_MANAGER   // Approve/reject onboarding only
  SUPPORT             // Read-only: view institutions and requests
  AUDITOR             // Read-only: audit/compliance view
}

enum PlatformStaffStatus {
  ACTIVE
  SUSPENDED
}

// B2B onboarding request (pending super admin approval)
model OnboardingRequest {
  id               String                    @id @default(cuid())
  deploymentMode   OnboardingDeploymentMode
  institutionName  String
  slug             String                   @unique // subdomain identifier
  contactPerson    String
  contactEmail     String
  phone            String?
  country          String
  website          String?
  approxStudents   Int?
  status           OnboardingRequestStatus  @default(PENDING)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?   @db.Text  // Required when rejecting; explains why request was rejected
  tenantId         String?                  // Set when approved
  tenant           Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // ----- Due diligence / institution profile -----
  addressLine1           String?
  addressLine2           String?
  addressCity            String?
  addressStateRegion     String?
  addressPostalCode      String?
  yearFounded            Int?
  institutionType        String?   // e.g. Public university, Private college, K-12 district
  legalEntityName        String?   // If different from institution name
  taxIdOrRegistrationNumber String?
  accreditationStatus   String?   // Accredited, Not accredited, In progress, Not applicable
  accreditationBody     String?   // Name of accrediting body
  accreditationCertificateUrl String?  // Link to certificate document
  missionOrDescription  String?   @db.Text
  numberOfCampuses      Int?

  // Financial verification (required before approval)
  financialVerifiedAt   DateTime?   // When platform admin verified payment received
  financialVerifiedBy   String?     // Clerk user ID of admin who verified
  quotationSentAt      DateTime?   // When onboarding quotation/invoice was sent to institution
  quotationInvoiceNumber String?   // Assigned when quotation is sent (e.g. SILS-0001)
  invoiceAccessToken   String?     @unique // Token for public invoice URL (sent in quotation email)
  receiptAccessToken   String?     @unique // Token for receipt URL (set when payment verified; email contains link)
  invoiceSnapshot      Json?       // Immutable copy of invoice at send time (request + settings) for reference
  receiptSnapshot      Json?       // Immutable copy of receipt at payment time for reference
  termsAcceptedAt     DateTime?   // When institution accepted terms via quotation link (before approval)

  @@index([status])
  @@index([createdAt])
}

// ----- Tenant (Clerk Organization mapping) -----
model Tenant {
  id              String        @id @default(cuid())
  clerkOrgId      String        @unique // Clerk Organization ID
  name            String
  slug            String        @unique // subdomain or identifier
  deploymentMode  DeploymentMode @default(LMS)
  status          TenantStatus  @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Terms & Conditions: institution must accept before full access
  termsAcceptedAt DateTime?
  // Payment: set when onboarding payment was verified (before or at approval)
  paymentVerifiedAt DateTime?

  // Structured feature flags (preferred over JSON)
  featureFlags    FeatureFlags?
  // Legacy JSON fallback: { sisEnabled, skillsGraphEnabled, pwaEnabled, lowBandwidthEnabled }
  featureFlagsJson Json?

  users           UserTenantRole[]
  courses         Course[]
  calendarEvents  CalendarEvent[]
  onboardingRequests OnboardingRequest[]
  faculties       Faculty[]
  departments     Department[]
  frictionSignals FrictionSignal[]
  interventionBriefs InterventionBrief[]
  studentMasteryStates StudentMasteryState[]
  studentModuleProgress StudentModuleProgress[]
  studentCompetencies  StudentCompetency[]
  verifiableCredentials VerifiableCredential[]
  huddles         Huddle[]
  liveSessions    LiveSession[]
  whiteboardSessions WhiteboardSession[]
  xrSessions      XRSession[]
  studentPreferences StudentPreference[]
  wellnessLogs    WellnessLog[]
  equityMetrics   EquityMetric[]
}

// ----- Feature flags (per-tenant, structured) -----
model FeatureFlags {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sisEnabled          Boolean  @default(false)
  skillsGraphEnabled  Boolean  @default(false)
  pwaEnabled          Boolean  @default(true)
  lowBandwidthEnabled Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ----- User <-> Tenant (many-to-many with role) -----
model UserTenantRole {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clerkUserId String   // Clerk User ID
  userId      String?  // Optional link to User when synced
  user        User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  role        UserRole
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, clerkUserId])
  @@index([clerkUserId])
  @@index([tenantId])
  @@index([userId])
}

// ----- User (minimal; auth is Clerk) -----
model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String?
  firstName   String?
  lastName    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantRoles UserTenantRole[]
}

// ----- Platform-level admins (super admins; can manage all institutions) -----
model PlatformAdmin {
  id          String              @id @default(cuid())
  clerkUserId String              @unique
  email       String?             // Denormalized for display; synced from Clerk when adding
  role        PlatformRole        @default(PLATFORM_ADMIN)
  status      PlatformStaffStatus @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

// ----- LMS Enums -----
enum CourseMode {
  SYNC   // Synchronous / live
  ASYNC  // Self-paced / asynchronous
}

enum AssignmentType {
  QUIZ
  ESSAY
  PROJECT
  DISCUSSION
  OTHER
}

enum GradebookStatus {
  DRAFT
  PUBLISHED
}

enum CalendarEventType {
  CLASS
  DEADLINE
  EXAM
  OTHER
}

// ----- Course -----
model Course {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  description String?    @db.Text
  createdBy   String?    // Clerk user ID of creator
  mode        CourseMode @default(ASYNC)
  published   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, createdBy])

  modules            Module[]
  gradebookEntries   GradebookEntry[]
  programmeLinks     CourseProgrammeLink[]
  liveSessions       LiveSession[]
  huddles            Huddle[]
}

// ----- Module (within a course) -----
// Phase 8: dynamic_content = AI-generated alternative content / micro-scaffolds per pathway;
// adaptive_pathways = branching steps (condition → path) for real-time forking.
model Module {
  id                String   @id @default(cuid())
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title             String
  order             Int      @default(0)
  contentType       String?  // e.g. "text", "video", "embed", "file"
  contentJson       Json?    // Flexible content payload
  dynamicContent    Json?    // Phase 8: AI-generated alternatives, micro-scaffolds keyed by pathway/condition
  adaptivePathways  Json?    // Phase 8: [{ condition, path, steps[] }] for branching
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([courseId])

  assignments         Assignment[]
  rubrics             Rubric[]
  studentProgress     StudentModuleProgress[]
}

// Phase 8: Per-student per-module progress for adaptive pathways and mastery.
model StudentModuleProgress {
  id                   String   @id @default(cuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId             String   // Clerk user ID
  moduleId              String
  module                Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  masteryScore         Float?    // 0–1 or 0–100; derived from quizzes / coach
  currentPathwayStep   Int?     // Index in adaptive_pathways.steps
  frictionHistory      Json?    // [{ at, signalType, payload }] for analytics
  updatedAt             DateTime @updatedAt

  @@unique([tenantId, studentId, moduleId])
  @@index([tenantId, studentId])
  @@index([moduleId])
}

// ----- Assignment (within a module) -----
model Assignment {
  id         String         @id @default(cuid())
  moduleId   String
  module     Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title      String
  type       AssignmentType @default(OTHER)
  dueDate    DateTime?
  rubricJson Json?
  rubricId   String?        // Optional: link to first-class Rubric for AI grading
  rubric     Rubric?       @relation(fields: [rubricId], references: [id], onDelete: SetNull)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([moduleId])
  @@index([rubricId])

  submissions Submission[]
}

// ----- Rubric (per module; used by AI grading and SpeedGrader) -----
model Rubric {
  id        String   @id @default(cuid())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  name      String
  criteria  Json     // [{ id, name, description, maxPoints, weight? }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId])
  assignments Assignment[]
}

// ----- Submission (student work for an assignment) -----
model Submission {
  id              String    @id @default(cuid())
  assignmentId    String
  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId       String    // Clerk user ID
  content         String?   @db.Text
  attachmentsJson Json?     // Optional: [{ type: "file"|"media", url, name? }] for file/media viewer
  grade           String?   // e.g. "A", "85", or points
  feedback        String?   @db.Text
  // Phase 12: AI grading
  aiGrade         Json?     // Per-criterion scores and overall from AI
  aiFeedback      String?   @db.Text
  confidenceScore Float?
  humanOverride   Boolean   @default(false) // True when lecturer edits after AI
  gradeFinalizedAt DateTime? // When lecturer approved and pushed to SIS (if applicable)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([assignmentId])
  @@index([assignmentId, studentId])
}

// ----- GradebookEntry (per student per course) -----
model GradebookEntry {
  id         String          @id @default(cuid())
  studentId  String          // Clerk user ID
  courseId   String
  course     Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  finalGrade String?         // e.g. "A", "3.2 GPA"
  status     GradebookStatus @default(DRAFT)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([courseId, studentId])
  @@index([courseId])
  @@index([studentId])
}

// ----- SIS: Faculty → Department → Programme → Module (curriculum) -----
model Faculty {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments Department[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Department {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  facultyId  String
  faculty    Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  name       String
  code       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  programmes Programme[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([facultyId])
}

model Programme {
  id             String   @id @default(cuid())
  departmentId   String
  department     Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name           String
  code           String
  curriculumJson Json?    // Structured curriculum (outline, learning outcomes at programme level)
  credits        Int      @default(0) // Total credits for programme
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modules      ProgrammeModule[]
  enrollments  ProgrammeEnrollment[]
  courseLinks  CourseProgrammeLink[]
  competencies Competency[]
  xrLabs       XR_Lab[]

  @@unique([departmentId, code])
  @@index([departmentId])
}

// ----- Phase 10: Native XR / Immersive Labs (browser-based, no external plugins) -----
enum XrType {
  AR
  VR
  THREE_D
}

model XR_Lab {
  id                String   @id @default(cuid())
  programmeId       String
  programme         Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  programmeModuleId String?  // Optional: link to specific programme module
  programmeModule   ProgrammeModule? @relation(fields: [programmeModuleId], references: [id], onDelete: SetNull)
  title             String
  xrType            XrType   // ar | vr | 3d
  sceneConfig       Json     // A-Frame/Three.js scene definition, entities, assets, behaviours
  masteryMetrics    Json     // Which competencies/steps contribute to mastery; thresholds
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sessions XRSession[]

  @@index([programmeId])
  @@index([programmeModuleId])
}

model XRSession {
  id                String   @id @default(cuid())
  xrLabId           String
  xrLab             XR_Lab   @relation(fields: [xrLabId], references: [id], onDelete: Cascade)
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId         String   // Clerk user ID
  startedAt         DateTime @default(now())
  endedAt           DateTime?
  interactionData   Json?    // Time spent, correct actions, errors, events
  performanceMetrics Json?   // Derived: score, completion, etc.
  createdAt         DateTime @default(now())

  @@index([xrLabId])
  @@index([tenantId, studentId])
}

// ----- Phase 9: Portable Competency Graph + Verifiable Credentials (PGVector) -----
model Competency {
  id          String   @id @default(cuid())
  programmeId String
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  code        String
  title       String
  description String?  @db.Text
  credits     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studentCompetencies    StudentCompetency[]
  verifiableCredentials VerifiableCredential[]

  @@unique([programmeId, code])
  @@index([programmeId])
}

model StudentCompetency {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId       String   // Clerk user ID
  competencyId    String
  competency      Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  masteryLevel    Float    @default(0) // 0–1
  evidenceJson    Json?    // Artefacts, links, module completions
  vectorEmbedding Unsupported("vector(1536)")? // For similarity search / job mapping
  lastUpdated     DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([tenantId, studentId, competencyId])
  @@index([tenantId])
  @@index([studentId])
  @@index([competencyId])
  // Vector index on vectorEmbedding is added via raw migration (ivfflat or hnsw)
}

enum VerifiableCredentialStatus {
  ISSUED
  REVOKED
  EXPIRED
}

model VerifiableCredential {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId    String
  competencyId String
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  vcJwt        String   @db.Text // VC-JWT from Veramo or stub
  issuedAt     DateTime @default(now())
  blockchainTx String?  @db.Text // Hedera / stub tx hash
  status       VerifiableCredentialStatus @default(ISSUED)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([studentId])
  @@index([competencyId])
  @@index([issuedAt])
}

enum SyllabusStatus {
  DRAFT          // Not yet generated or edited
  PENDING_REVIEW // AI-generated; lecturer must review
  PUBLISHED      // Lecturer approved
}

model ProgrammeModule {
  id                   String         @id @default(cuid())
  programmeId          String
  programme            Programme      @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  lecturerId          String?        // Clerk user ID of assigned lecturer
  title                String
  syllabusText         String?        @db.Text // Original uploaded syllabus text
  syllabusGeneratedJson Json?         // AI-generated: outline, outcomes, assignments, rubrics, tests, pathways
  syllabusStatus       SyllabusStatus @default(DRAFT)
  isCore               Boolean        @default(true)
  credits              Int            @default(0)
  prerequisites        Json?          // Array of ProgrammeModule ids
  order                Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  grades ProgrammeModuleGrade[]
  xrLabs XR_Lab[]

  @@index([programmeId])
  @@index([lecturerId])
}

model ProgrammeEnrollment {
  id          String    @id @default(cuid())
  studentId   String    // Clerk user ID
  programmeId String
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  enrolledAt  DateTime  @default(now())

  @@unique([programmeId, studentId])
  @@index([programmeId])
  @@index([studentId])
}

model ProgrammeModuleGrade {
  id               String          @id @default(cuid())
  studentId        String          // Clerk user ID
  programmeModuleId String
  programmeModule  ProgrammeModule @relation(fields: [programmeModuleId], references: [id], onDelete: Cascade)
  grade            String?         // e.g. "A", "85", "Pass"
  completedAt      DateTime?
  syncedAt         DateTime?       // When pushed from LMS
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([programmeModuleId, studentId])
  @@index([programmeModuleId])
  @@index([studentId])
}

model CourseProgrammeLink {
  id               String    @id @default(cuid())
  courseId         String    @unique // One course can link to at most one programme
  course           Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  programmeId      String
  programme        Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  programmeModuleId String?  // If set, course grade syncs to this programme module
  createdAt        DateTime  @default(now())

  @@index([programmeId])
}

// ----- CalendarEvent (tenant-level events) -----
model CalendarEvent {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  startTime DateTime
  endTime   DateTime
  type      CalendarEventType @default(OTHER)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([tenantId])
  @@index([tenantId, startTime])
}

// ----- Skills graph (with vector embedding for semantic search) -----
// SkillNode + SkillEdge form the skills graph; embedding column uses PGVector.
model SkillNode {
  id          String   @id @default(cuid())
  tenantId    String
  externalId  String?  // Optional external ID (e.g. from SIS)
  name        String
  description String?
  embedding   Unsupported("vector(1536)")? // OpenAI ada-002 / similar 1536-dim
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, externalId])
}

// Optional: edges for skill prerequisites
model SkillEdge {
  id        String   @id @default(cuid())
  tenantId  String
  fromId    String   // SkillNode id
  toId      String   // SkillNode id
  createdAt DateTime @default(now())

  @@unique([tenantId, fromId, toId])
  @@index([tenantId])
}

// ----- Platform finance settings (singleton: one row) -----
// Used on Admin > Finance > Settings. One record; create if missing.
model PlatformFinanceSettings {
  id            String   @id @default(cuid())
  pricingPlans  Json?    // { sis: { amount, currency, period }, lms: {}, hybrid: {} }
  paymentTerms  Json?    // { defaultTerms, dueDays, latePolicy }
  bankDetails   Json?    // { bankName, bban, swift, accountMasked, referenceFormat, instructions }
  taxCompliance Json?    // { taxId, vatNumber, invoicePrefix, nextNumber }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ----- Agentic AI: friction signals, intervention briefs, mastery state -----
// FrictionSignal: raw learning signals (dwell time, quiz errors, huddle activity, etc.)
enum FrictionSignalType {
  DWELL_TIME       // Long time on a page/section
  QUIZ_ERROR       // Wrong or repeated quiz answers
  HUDDLE_ACTIVITY  // Help-seeking or peer interaction
  REPEAT_ATTEMPT   // Re-attempting same content
  SKIP_OR_ABANDON  // Skipped or abandoned section
  OTHER
}

model FrictionSignal {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String            // Clerk user ID
  moduleId  String?           // LMS Module id
  courseId  String?            // LMS Course id
  signalType FrictionSignalType
  payload   Json?              // { durationSeconds?, errorCount?, attempt?, context? }
  createdAt DateTime          @default(now())

  @@index([tenantId, studentId])
  @@index([tenantId, studentId, moduleId])
  @@index([createdAt])
}

// InterventionBrief: agent-generated brief for lecturer (escalation) or in-app action
enum InterventionBriefType {
  MICRO_SCAFFOLD         // In-app hint / micro-scaffold
  ALTERNATIVE_EXPLANATION // Agent suggested alternative explanation
  BRANCHING_PATHWAY      // Suggested branching path
  LECTURER_INTERVENTION  // Brief sent to lecturer for human follow-up
}

enum InterventionBriefStatus {
  PENDING
  SENT
  ACKNOWLEDGED
}

model InterventionBrief {
  id             String                 @id @default(cuid())
  tenantId       String
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId      String
  moduleId       String?
  courseId       String?
  briefType      InterventionBriefType
  content        String                 @db.Text  // JSON or markdown summary
  status         InterventionBriefStatus @default(PENDING)
  createdByAgentAt DateTime             @default(now())
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([tenantId, studentId])
  @@index([tenantId, status])
  @@index([createdByAgentAt])
}

// StudentMasteryState: per-student per-module (and skills graph) state
model StudentMasteryState {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String
  moduleId  String?
  courseId  String?
  stateJson Json?    // { masteryLevel?, skills?: string[], confidence?, lastInterventionAt? }
  updatedAt DateTime @updatedAt

  @@unique([tenantId, studentId, moduleId])
  @@index([tenantId, studentId])
  @@index([tenantId, moduleId])
}

// ----- Phase 7: Social Learning, Live Classrooms, Whiteboard, Attendance -----

enum HuddleStatus {
  ACTIVE
  ENDED
}

model Huddle {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId  String?
  course    Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  moduleId  String?
  title     String
  createdBy String       // Clerk user ID of creator/moderator
  status    HuddleStatus @default(ACTIVE)
  startedAt DateTime     @default(now())
  endedAt   DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  messages HuddleMessage[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([courseId])
}

model HuddleMessage {
  id        String   @id @default(cuid())
  huddleId  String
  huddle    Huddle   @relation(fields: [huddleId], references: [id], onDelete: Cascade)
  authorId  String   // Clerk user ID
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([huddleId])
  @@index([huddleId, createdAt])
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
}

model LiveSession {
  id             String            @id @default(cuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId       String?
  course         Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  title          String
  createdBy      String            // Clerk user ID (lecturer / owner)
  provider       String            // "daily" | "livekit"
  externalRoomId String?           // Room ID from provider
  roomUrl        String?           @db.Text
  status         LiveSessionStatus @default(SCHEDULED)
  startedAt      DateTime?
  endedAt        DateTime?
  metadata       Json?             // Provider-specific config, recording flags, etc.
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  attendanceRecords AttendanceRecord[]
  whiteboardSessions WhiteboardSession[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([courseId])
  @@index([createdBy])
}

model WhiteboardSession {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  liveSessionId   String?
  liveSession     LiveSession?  @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  courseId        String?
  title           String
  createdBy       String        // Clerk user ID
  documentSnapshot Json?        // tldraw document state (shapes, bindings, etc.)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([liveSessionId])
}

model AttendanceRecord {
  id             String       @id @default(cuid())
  liveSessionId  String
  liveSession    LiveSession  @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  studentId      String       // Clerk user ID
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?
  engagementScore Int?        // 0-100 derived from WebRTC metadata (presence, audio/video activity)
  metadata       Json?        // Raw WebRTC/participant events for audit
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([liveSessionId, studentId])
  @@index([liveSessionId])
  @@index([studentId])
}

// ----- Phase 11: Student Success, Equity, Wellness & Global Layer -----
model StudentPreference {
  id                    String   @id @default(cuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId             String   // Clerk user ID
  preferredLanguage     String?  // e.g. "en", "es", "ar"
  accessibilitySettings Json?   // { reducedMotion, highContrast, fontSize, screenReader, etc. }
  lowBandwidthMode      Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([tenantId, studentId])
  @@index([tenantId])
  @@index([studentId])
}

enum WellnessNudgeType {
  WELLNESS_CHECKIN
  MOTIVATION
  TIME_MANAGEMENT
  STRESS_RELIEF
  EQUITY_SUPPORT
  OTHER
}

model WellnessLog {
  id        String           @id @default(cuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String           // Clerk user ID
  nudgeType WellnessNudgeType
  message   String           @db.Text
  response  String?          @db.Text // Student's optional response (e.g. "I'm doing okay")
  createdAt DateTime         @default(now())

  @@index([tenantId, studentId])
  @@index([tenantId, studentId, createdAt])
}

model EquityMetric {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId    String   // Clerk user ID
  firstGen     Boolean  @default(false)  // First-generation student
  lowIncome    Boolean  @default(false)
  neurodiverse Boolean  @default(false)
  caregiver    Boolean  @default(false)  // Primary caregiver responsibilities
  refugeeOrDisplaced Boolean @default(false)
  otherFlags   Json?    // Optional: { "veteran": true, "foster": false, ... } for extensibility
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, studentId])
  @@index([tenantId])
  @@index([studentId])
}
