// Prisma schema for SILS — Student Information and Learning System
// Database: Neon Postgres with full PGVector extension (vector search)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ----- Extensions (PGVector) -----
// Enable in Neon: CREATE EXTENSION IF NOT EXISTS vector;
// vector(1536) matches OpenAI text-embedding-ada-002 / compatible embeddings.

// ----- Enums -----
enum UserRole {
  OWNER
  ADMIN
  INSTRUCTOR
  LEARNER
  SUPPORT
  FINANCE_OFFICER
  FINANCE_DIRECTOR
  ADVANCEMENT_OFFICER
  DEVELOPMENT_DIRECTOR
  CAREER_SERVICES   // Phase 26: Career hub, job board, mentorship
  ALUMNI_RELATIONS  // Phase 26: Alumni directory, events, donor overlap
}

enum DeploymentMode {
  SIS
  LMS
  HYBRID
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

// Phase 15: Scope for role assignment (tenant-wide, school, department, programme)
enum RoleScopeType {
  TENANT
  SCHOOL
  DEPARTMENT
  PROGRAMME
}

// Onboarding: deployment mode choice during request (SIS, LMS, Hybrid SIS+LMS)
enum OnboardingDeploymentMode {
  SIS
  LMS
  HYBRID
}

enum OnboardingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Phase 16: Academic calendar — term types and status
enum AcademicTermType {
  SEMESTER
  TRIMESTER
  ACADEMIC_YEAR
  QUARTER
}

enum AcademicTermStatus {
  DRAFT
  PUBLISHED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  ONGOING
  ENDED
}

// Phase 18: Examination management
enum ExamType {
  MIDTERM
  FINAL
  PRACTICAL
  PROJECT
}

enum ExaminationStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Phase 22: Plagiarism & Originality — provider used for the check
enum PlagiarismReportProvider {
  turnitin
  copyleaks
  ai_native
}

// Phase 23: Library Services — resource type and access level
enum LibraryResourceType {
  book
  article
  video
  eBook
}

enum LibraryAccessLevel {
  OPEN       // Anyone in tenant
  COURSE     // Linked to course/programme
  RESERVE    // Reserve only
}

// Phase 17: Announcement target scope (all, school, department, programme, module, role)
enum AnnouncementScopeType {
  ALL
  SCHOOL
  DEPARTMENT
  PROGRAMME
  MODULE
  ROLE
}

// Phase 17: Appointment type and status
enum AppointmentType {
  OFFICE_HOURS
  ADVISING
  EXAM_REVIEW
  MENTORSHIP
}

enum AppointmentStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
  AVAILABLE  // Open slot (e.g. office hours not yet booked)
}

enum StudentRegistrationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  WAITLISTED
}

// Platform (super admin) staff roles — who can do what on the admin side
enum PlatformRole {
  PLATFORM_OWNER       // Full control: staff, institutions, onboarding
  PLATFORM_ADMIN       // Institutions + onboarding; cannot manage staff
  ONBOARDING_MANAGER   // Approve/reject onboarding only
  SUPPORT             // Read-only: view institutions and requests
  AUDITOR             // Read-only: audit/compliance view
}

enum PlatformStaffStatus {
  ACTIVE
  SUSPENDED
}

// B2B onboarding request (pending super admin approval)
model OnboardingRequest {
  id               String                    @id @default(cuid())
  deploymentMode   OnboardingDeploymentMode
  institutionName  String
  slug             String                   @unique // subdomain identifier
  contactPerson    String
  contactEmail     String
  phone            String?
  country          String
  website          String?
  approxStudents   Int?
  status           OnboardingRequestStatus  @default(PENDING)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?   @db.Text  // Required when rejecting; explains why request was rejected
  tenantId         String?                  // Set when approved
  tenant           Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // ----- Due diligence / institution profile -----
  addressLine1           String?
  addressLine2           String?
  addressCity            String?
  addressStateRegion     String?
  addressPostalCode      String?
  yearFounded            Int?
  institutionType        String?   // e.g. Public university, Private college, K-12 district
  legalEntityName        String?   // If different from institution name
  taxIdOrRegistrationNumber String?
  accreditationStatus   String?   // Accredited, Not accredited, In progress, Not applicable
  accreditationBody     String?   // Name of accrediting body
  accreditationCertificateUrl String?  // Link to certificate document
  missionOrDescription  String?   @db.Text
  numberOfCampuses      Int?

  // Financial verification (required before approval)
  financialVerifiedAt   DateTime?   // When platform admin verified payment received
  financialVerifiedBy   String?     // Clerk user ID of admin who verified
  quotationSentAt      DateTime?   // When onboarding quotation/invoice was sent to institution
  quotationInvoiceNumber String?   // Assigned when quotation is sent (e.g. SILS-0001)
  invoiceAccessToken   String?     @unique // Token for public invoice URL (sent in quotation email)
  receiptAccessToken   String?     @unique // Token for receipt URL (set when payment verified; email contains link)
  invoiceSnapshot      Json?       // Immutable copy of invoice at send time (request + settings) for reference
  receiptSnapshot      Json?       // Immutable copy of receipt at payment time for reference
  termsAcceptedAt     DateTime?   // When institution accepted terms via quotation link (before approval)

  @@index([status])
  @@index([createdAt])
}

// ----- Tenant (Clerk Organization mapping) -----
model Tenant {
  id              String        @id @default(cuid())
  clerkOrgId      String        @unique // Clerk Organization ID
  name            String
  slug            String        @unique // subdomain or identifier
  deploymentMode  DeploymentMode @default(LMS)
  status          TenantStatus  @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Terms & Conditions: institution must accept before full access
  termsAcceptedAt DateTime?
  // Payment: set when onboarding payment was verified (before or at approval)
  paymentVerifiedAt DateTime?

  // Structured feature flags (preferred over JSON)
  featureFlags    FeatureFlags?
  // Legacy JSON fallback: { sisEnabled, skillsGraphEnabled, pwaEnabled, lowBandwidthEnabled }
  featureFlagsJson Json?

  users           UserTenantRole[]
  courses         Course[]
  calendarEvents  CalendarEvent[]
  onboardingRequests OnboardingRequest[]
  faculties       Faculty[]
  schools         School[]       // Phase 15: optional Schools/Colleges layer (when schoolsEnabled)
  departments     Department[]
  frictionSignals FrictionSignal[]
  interventionBriefs InterventionBrief[]
  studentMasteryStates StudentMasteryState[]
  studentModuleProgress StudentModuleProgress[]
  studentCompetencies  StudentCompetency[]
  verifiableCredentials VerifiableCredential[]
  huddles         Huddle[]
  liveSessions    LiveSession[]
  whiteboardSessions WhiteboardSession[]
  xrSessions      XRSession[]
  studentPreferences StudentPreference[]
  wellnessLogs    WellnessLog[]
  equityMetrics   EquityMetric[]
  financialAidApplications FinancialAidApplication[]
  invoices       Invoice[]
  admissionWorkflows AdmissionWorkflow[]
  admissionApplications AdmissionApplication[]
  academicTerms       AcademicTerm[]
  studentRegistrations StudentRegistration[]
  announcements       Announcement[]
  appointments        Appointment[]
  availabilitySlots   AvailabilitySlot[]
  examinations        Examination[]
  analyticsSnapshots   AnalyticsSnapshot[]
  rooms               Room[]
  schedules           Schedule[]
  notificationTemplates NotificationTemplate[]
  notifications        Notification[]
  notificationPreferences NotificationPreference[]
  libraryResources   LibraryResource[]
  facultyProfiles    FacultyProfile[]
  workloadAssignments WorkloadAssignment[]
  facultyLeaves      FacultyLeave[]
  donors             Donor[]
  campaigns           Campaign[]
  alumniProfiles     AlumniProfile[]
  careerOpportunities CareerOpportunity[]
  alumniMentorships   AlumniMentorship[]
  events             Event[]
  institutionalEvents InstitutionalEvent[]
  academicYearCalendars AcademicYearCalendar[]
  systemInsights     SystemInsight[]
}

// ----- Phase 25: Donor, Fundraising & Advancement CRM -----
enum CampaignStatus {
  DRAFT
  ACTIVE
  ENDED
  CANCELLED
}

enum AdvancementInteractionType {
  CALL
  EMAIL
  MEETING
  EVENT
  NOTE
}

model Donor {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId         String?   // Optional link to external contact system
  name              String
  email             String
  lifetimeValue     Decimal   @default(0) @db.Decimal(12, 2)
  affinityScore     Float     @default(0)  // 0–1 or 0–100; engagement/affinity
  lastContactDate   DateTime? @db.Date
  tags              String[]  @default([])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  donations             Donation[]
  advancementInteractions AdvancementInteraction[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([lastContactDate])
}

model Campaign {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schoolId    String?
  school      School?        @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  name        String
  goalAmount  Decimal        @db.Decimal(14, 2)
  startDate   DateTime       @db.Date
  endDate     DateTime       @db.Date
  status      CampaignStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  donations Donation[]

  @@index([tenantId])
  @@index([schoolId])
  @@index([status])
}

model Donation {
  id          String   @id @default(cuid())
  donorId     String
  donor       Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime @db.Date
  designation String?  @db.Text
  receiptSent Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([donorId])
  @@index([campaignId])
  @@index([date])
}

model AdvancementInteraction {
  id       String                    @id @default(cuid())
  donorId  String
  donor    Donor                     @relation(fields: [donorId], references: [id], onDelete: Cascade)
  type     AdvancementInteractionType
  notes    String?                   @db.Text
  date     DateTime                  @db.Date
  userId   String                    // Clerk user ID of officer who logged the interaction
  createdAt DateTime                 @default(now())

  @@index([donorId])
  @@index([date])
  @@index([userId])
}

// ----- Feature flags (per-tenant, structured) -----
model FeatureFlags {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sisEnabled          Boolean  @default(false)
  skillsGraphEnabled  Boolean  @default(false)
  pwaEnabled          Boolean  @default(true)
  lowBandwidthEnabled Boolean  @default(false)
  schoolsEnabled      Boolean  @default(false) // Phase 15: Schools/Colleges layer above Departments
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ----- User <-> Tenant (many-to-many with role) -----
// Phase 15: Optional scope (school/department/programme); null = tenant-wide.
model UserTenantRole {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clerkUserId String
  userId      String?       // Optional link to User when synced
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  role        UserRole
  scopeType   RoleScopeType? // When null, role is tenant-wide
  scopeId     String?       // School id, Department id, or Programme id when scopeType is set
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId, clerkUserId])
  @@index([clerkUserId])
  @@index([tenantId])
  @@index([userId])
  @@index([scopeType, scopeId])
}

// ----- User (minimal; auth is Clerk) -----
model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String?
  firstName   String?
  lastName    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantRoles UserTenantRole[]
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  facultyProfiles FacultyProfile[]
  alumniProfile AlumniProfile[]
}

// ----- Platform-level admins (super admins; can manage all institutions) -----
model PlatformAdmin {
  id          String              @id @default(cuid())
  clerkUserId String              @unique
  email       String?             // Denormalized for display; synced from Clerk when adding
  role        PlatformRole        @default(PLATFORM_ADMIN)
  status      PlatformStaffStatus @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

// ----- LMS Enums -----
enum CourseMode {
  SYNC   // Synchronous / live
  ASYNC  // Self-paced / asynchronous
}

enum AssignmentType {
  QUIZ
  ESSAY
  PROJECT
  DISCUSSION
  OTHER
}

enum GradebookStatus {
  DRAFT
  PUBLISHED
}

enum CalendarEventType {
  CLASS
  DEADLINE
  EXAM
  OTHER
}

// ----- Course -----
model Course {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  description String?    @db.Text
  createdBy   String?    // Clerk user ID of creator
  mode        CourseMode @default(ASYNC)
  published   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, createdBy])

  modules            Module[]
  gradebookEntries   GradebookEntry[]
  programmeLinks     CourseProgrammeLink[]
  liveSessions       LiveSession[]
  huddles            Huddle[]
}

// ----- Module (within a course) -----
// Phase 8: dynamic_content = AI-generated alternative content / micro-scaffolds per pathway;
// adaptive_pathways = branching steps (condition → path) for real-time forking.
model Module {
  id                String   @id @default(cuid())
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title             String
  order             Int      @default(0)
  contentType       String?  // e.g. "text", "video", "embed", "file"
  contentJson       Json?    // Flexible content payload
  dynamicContent    Json?    // Phase 8: AI-generated alternatives, micro-scaffolds keyed by pathway/condition
  adaptivePathways  Json?    // Phase 8: [{ condition, path, steps[] }] for branching
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([courseId])

  assignments         Assignment[]
  rubrics             Rubric[]
  studentProgress     StudentModuleProgress[]
}

// Phase 8: Per-student per-module progress for adaptive pathways and mastery.
model StudentModuleProgress {
  id                   String   @id @default(cuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId             String   // Clerk user ID
  moduleId              String
  module                Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  masteryScore         Float?    // 0–1 or 0–100; derived from quizzes / coach
  currentPathwayStep   Int?     // Index in adaptive_pathways.steps
  frictionHistory      Json?    // [{ at, signalType, payload }] for analytics
  updatedAt             DateTime @updatedAt

  @@unique([tenantId, studentId, moduleId])
  @@index([tenantId, studentId])
  @@index([moduleId])
}

// ----- Assignment (within a module) -----
model Assignment {
  id         String         @id @default(cuid())
  moduleId   String
  module     Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title      String
  type       AssignmentType @default(OTHER)
  dueDate    DateTime?
  rubricJson Json?
  rubricId   String?        // Optional: link to first-class Rubric for AI grading
  rubric     Rubric?       @relation(fields: [rubricId], references: [id], onDelete: SetNull)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([moduleId])
  @@index([rubricId])

  submissions Submission[]
}

// ----- Rubric (per module; used by AI grading and SpeedGrader) -----
model Rubric {
  id        String   @id @default(cuid())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  name      String
  criteria  Json     // [{ id, name, description, maxPoints, weight? }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId])
  assignments Assignment[]
}

// ----- Submission (student work for an assignment) -----
model Submission {
  id              String    @id @default(cuid())
  assignmentId    String
  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId       String    // Clerk user ID
  content         String?   @db.Text
  attachmentsJson Json?     // Optional: [{ type: "file"|"media", url, name? }] for file/media viewer
  grade           String?   // e.g. "A", "85", or points
  feedback        String?   @db.Text
  // Phase 12: AI grading
  aiGrade         Json?     // Per-criterion scores and overall from AI
  aiFeedback      String?   @db.Text
  confidenceScore Float?
  humanOverride   Boolean   @default(false) // True when lecturer edits after AI
  gradeFinalizedAt DateTime? // When lecturer approved and pushed to SIS (if applicable)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plagiarismReports PlagiarismReport[]

  @@index([assignmentId])
  @@index([assignmentId, studentId])
}

// ----- Phase 22: Plagiarism & Originality Report (per submission) -----
model PlagiarismReport {
  id               String                  @id @default(cuid())
  submissionId     String
  submission       Submission              @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  overallScore     Float                    // 0–100 similarity percentage
  detailedMatches  Json                    // [{ source, similarityPct, excerpt, startOffset?, endOffset?, sourceUrl? }]
  reportUrl        String?   @db.Text       // External report URL (Turnitin/Copyleaks) when available
  checkedAt        DateTime  @default(now())
  provider         PlagiarismReportProvider // turnitin | copyleaks | ai_native

  @@index([submissionId])
  @@index([checkedAt])
}

// ----- GradebookEntry (per student per course) -----
model GradebookEntry {
  id         String          @id @default(cuid())
  studentId  String          // Clerk user ID
  courseId   String
  course     Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  finalGrade String?         // e.g. "A", "3.2 GPA"
  status     GradebookStatus @default(DRAFT)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([courseId, studentId])
  @@index([courseId])
  @@index([studentId])
}

// ----- SIS: Faculty → Department → Programme → Module (curriculum) -----
// Phase 15: Optional School layer above Department (when schoolsEnabled).
// Hierarchy: School? → Department → Programme (Department may belong to Faculty and/or School).

model School {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  code        String
  deanId      String?   // Clerk user id
  description String?   @db.Text
  order       Int       @default(0) // For drag-and-drop reordering
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  departments Department[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rooms       Room[]
  facultyProfiles FacultyProfile[]
  campaigns   Campaign[]
  institutionalEvents InstitutionalEvent[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([deanId])
}

model Faculty {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments Department[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Department {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  facultyId  String
  faculty    Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  schoolId   String?   // Phase 15: optional; when schoolsEnabled, department can belong to a School
  school     School?   @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  name       String
  code       String?
  order      Int       @default(0) // For drag-and-drop reordering within faculty/school
  createdAt  DateTime  @default(now())
  updatedAt  DateTime @updatedAt

  programmes Programme[]
  facultyProfiles FacultyProfile[]
  institutionalEvents InstitutionalEvent[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([facultyId])
  @@index([schoolId])
}

model Programme {
  id             String   @id @default(cuid())
  departmentId   String
  department     Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name           String
  code           String
  curriculumJson Json?    // Structured curriculum (outline, learning outcomes at programme level)
  credits        Int      @default(0) // Total credits for programme
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modules      ProgrammeModule[]
  enrollments  ProgrammeEnrollment[]
  courseLinks  CourseProgrammeLink[]
  competencies Competency[]
  xrLabs       XR_Lab[]
  financialAidApplications FinancialAidApplication[]
  admissionApplications AdmissionApplication[]
  studentRegistrations StudentRegistration[]
  examinations        Examination[]
  schedules           Schedule[]
  readingLists        ReadingList[]
  reserves            Reserve[]
  institutionalEvents InstitutionalEvent[]

  @@unique([departmentId, code])
  @@index([departmentId])
}

// ----- Phase 10: Native XR / Immersive Labs (browser-based, no external plugins) -----
enum XrType {
  AR
  VR
  THREE_D
}

model XR_Lab {
  id                String   @id @default(cuid())
  programmeId       String
  programme         Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  programmeModuleId String?  // Optional: link to specific programme module
  programmeModule   ProgrammeModule? @relation(fields: [programmeModuleId], references: [id], onDelete: SetNull)
  title             String
  xrType            XrType   // ar | vr | 3d
  sceneConfig       Json     // A-Frame/Three.js scene definition, entities, assets, behaviours
  masteryMetrics    Json     // Which competencies/steps contribute to mastery; thresholds
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sessions XRSession[]

  @@index([programmeId])
  @@index([programmeModuleId])
}

model XRSession {
  id                String   @id @default(cuid())
  xrLabId           String
  xrLab             XR_Lab   @relation(fields: [xrLabId], references: [id], onDelete: Cascade)
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId         String   // Clerk user ID
  startedAt         DateTime @default(now())
  endedAt           DateTime?
  interactionData   Json?    // Time spent, correct actions, errors, events
  performanceMetrics Json?   // Derived: score, completion, etc.
  createdAt         DateTime @default(now())

  @@index([xrLabId])
  @@index([tenantId, studentId])
}

// ----- Phase 9: Portable Competency Graph + Verifiable Credentials (PGVector) -----
model Competency {
  id          String   @id @default(cuid())
  programmeId String
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  code        String
  title       String
  description String?  @db.Text
  credits     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studentCompetencies    StudentCompetency[]
  verifiableCredentials VerifiableCredential[]

  @@unique([programmeId, code])
  @@index([programmeId])
}

model StudentCompetency {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId       String   // Clerk user ID
  competencyId    String
  competency      Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  masteryLevel    Float    @default(0) // 0–1
  evidenceJson    Json?    // Artefacts, links, module completions
  vectorEmbedding Unsupported("vector(1536)")? // For similarity search / job mapping
  lastUpdated     DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([tenantId, studentId, competencyId])
  @@index([tenantId])
  @@index([studentId])
  @@index([competencyId])
  // Vector index on vectorEmbedding is added via raw migration (ivfflat or hnsw)
}

enum VerifiableCredentialStatus {
  ISSUED
  REVOKED
  EXPIRED
}

model VerifiableCredential {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId    String
  competencyId String
  competency   Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  vcJwt        String   @db.Text // VC-JWT from Veramo or stub
  issuedAt     DateTime @default(now())
  blockchainTx String?  @db.Text // Hedera / stub tx hash
  status       VerifiableCredentialStatus @default(ISSUED)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([studentId])
  @@index([competencyId])
  @@index([issuedAt])
}

enum SyllabusStatus {
  DRAFT          // Not yet generated or edited
  PENDING_REVIEW // AI-generated; lecturer must review
  PUBLISHED      // Lecturer approved
}

model ProgrammeModule {
  id                   String         @id @default(cuid())
  programmeId          String
  programme            Programme      @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  lecturerId          String?        // Clerk user ID of assigned lecturer
  title                String
  syllabusText         String?        @db.Text // Original uploaded syllabus text
  syllabusGeneratedJson Json?         // AI-generated: outline, outcomes, assignments, rubrics, tests, pathways
  syllabusStatus       SyllabusStatus @default(DRAFT)
  isCore               Boolean        @default(true)
  credits              Int            @default(0)
  prerequisites        Json?          // Array of ProgrammeModule ids
  order                Int            @default(0)
  academicTermId       String?        // Phase 16: optional term when this module is offered
  academicTerm         AcademicTerm?  @relation(fields: [academicTermId], references: [id], onDelete: SetNull)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  grades ProgrammeModuleGrade[]
  xrLabs XR_Lab[]
  examinations Examination[]
  schedules Schedule[]
  readingLists ReadingList[]
  workloadAssignments WorkloadAssignment[]

  @@index([programmeId])
  @@index([lecturerId])
  @@index([academicTermId])
}

model ProgrammeEnrollment {
  id          String    @id @default(cuid())
  studentId   String    // Clerk user ID
  programmeId String
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  enrolledAt  DateTime  @default(now())

  @@unique([programmeId, studentId])
  @@index([programmeId])
  @@index([studentId])
}

// Phase 16: Per-term student registration (programme + modules, waitlist, approval)
model StudentRegistration {
  id                String                    @id @default(cuid())
  tenantId          String
  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId         String                    // Clerk user ID
  programmeId       String
  programme         Programme                 @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  termId            String
  term              AcademicTerm              @relation(fields: [termId], references: [id], onDelete: Cascade)
  status            StudentRegistrationStatus @default(DRAFT)
  registeredModules Json?                     // { enrolled: string[], waitlist: string[] } — ProgrammeModule ids
  submittedAt       DateTime?
  approvedAt        DateTime?
  approvedBy        String?                   // Clerk user ID
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@unique([termId, studentId, programmeId])
  @@index([tenantId])
  @@index([studentId])
  @@index([termId])
  @@index([programmeId])
  @@index([status])
}

model ProgrammeModuleGrade {
  id               String          @id @default(cuid())
  studentId        String          // Clerk user ID
  programmeModuleId String
  programmeModule  ProgrammeModule @relation(fields: [programmeModuleId], references: [id], onDelete: Cascade)
  grade            String?         // e.g. "A", "85", "Pass"
  completedAt      DateTime?
  syncedAt         DateTime?       // When pushed from LMS
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([programmeModuleId, studentId])
  @@index([programmeModuleId])
  @@index([studentId])
}

model CourseProgrammeLink {
  id               String    @id @default(cuid())
  courseId         String    @unique // One course can link to at most one programme
  course           Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  programmeId      String
  programme        Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  programmeModuleId String?  // If set, course grade syncs to this programme module
  createdAt        DateTime  @default(now())

  @@index([programmeId])
}

// ----- CalendarEvent (tenant-level events) -----
model CalendarEvent {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  startTime DateTime
  endTime   DateTime
  type      CalendarEventType @default(OTHER)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([tenantId])
  @@index([tenantId, startTime])
}

// ----- Phase 17: Centralized Announcements (scoped, multi-channel) -----
model Announcement {
  id               String               @id @default(cuid())
  tenantId         String
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title            String
  body             String                @db.Text
  targetScopeType  AnnouncementScopeType // all | school | department | programme | module | role
  targetScopeId    String?               // Id of school, department, programme, module, or role name/code when scope is not ALL
  scheduledAt      DateTime?             // When to show/send; null = immediately
  expiresAt        DateTime?             // When to hide/expire
  createdBy        String                // Clerk user ID of creator
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([tenantId])
  @@index([tenantId, scheduledAt, expiresAt])
  @@index([targetScopeType, targetScopeId])
}

// ----- Phase 17: Appointments (office hours, advising, exam review, mentorship) -----
model Appointment {
  id               String            @id @default(cuid())
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hostUserId       String            // Clerk user ID (e.g. faculty)
  attendeeUserId   String?           // Clerk user ID when booked; null for open availability slots
  title            String
  startTime        DateTime
  endTime          DateTime
  type             AppointmentType   @default(OFFICE_HOURS)
  status           AppointmentStatus @default(SCHEDULED)
  location         String?           // Room, link, or "Video call"
  notes            String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([tenantId])
  @@index([tenantId, hostUserId])
  @@index([tenantId, attendeeUserId])
  @@index([tenantId, startTime])
}

// ----- Phase 17: Recurring availability (e.g. office hours) — weekly slots -----
model AvailabilitySlot {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hostUserId   String   // Clerk user ID
  dayOfWeek    Int      // 0 = Sunday, 6 = Saturday
  startMinutes Int      // Minutes from midnight (0–1439)
  endMinutes   Int      // Minutes from midnight (0–1439)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, hostUserId])
}

// ----- Phase 16: Academic Calendar & Term Management -----
model AcademicTerm {
  id                      String              @id @default(cuid())
  tenantId                String
  tenant                  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                    String              // e.g. "Fall 2025", "Trimester 1"
  type                    AcademicTermType    // SEMESTER | TRIMESTER | ACADEMIC_YEAR | QUARTER
  startDate               DateTime            @db.Date
  endDate                 DateTime            @db.Date
  registrationOpenDate    DateTime?           @db.Date
  registrationCloseDate   DateTime?           @db.Date
  status                  AcademicTermStatus @default(DRAFT)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  studentRegistrations StudentRegistration[]
  programmeModules      ProgrammeModule[]
  examinations         Examination[]
  schedules            Schedule[]
  workloadAssignments  WorkloadAssignment[]

  @@index([tenantId])
  @@index([tenantId, startDate])
  @@index([status])
}

// ----- Phase 18: Examination Management (AI-powered scheduling, seating, result analysis) -----
model Examination {
  id                 String            @id @default(cuid())
  tenantId           String
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  programmeId        String
  programme          Programme         @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  moduleId           String            // ProgrammeModule id
  module             ProgrammeModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  termId             String
  term               AcademicTerm      @relation(fields: [termId], references: [id], onDelete: Cascade)
  title              String
  examType           ExamType          // midterm | final | practical | project
  date               DateTime          @db.Date
  durationMinutes    Int               @default(120)
  location           String?           // Room or venue
  proctoringRequired Boolean           @default(false)
  status             ExaminationStatus @default(DRAFT)
  aiScheduleInsights  Json?             // Phase 18: AI scheduler output (conflicts, workload, suggestions)
  aiResultAnalysis   Json?             // Phase 18: AI result analysis summary (patterns, equity, remediation)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  seatings           ExamSeating[]
  specialArrangements SpecialArrangement[]
  results            ExamResult[]

  @@index([tenantId])
  @@index([termId])
  @@index([programmeId])
  @@index([moduleId])
  @@index([date])
  @@index([status])
}

model ExamSeating {
  id            String     @id @default(cuid())
  examinationId String
  examination   Examination @relation(fields: [examinationId], references: [id], onDelete: Cascade)
  studentId     String     // Clerk user ID
  seatNumber    String     // e.g. "A1", "12"
  room          String?    // Override room for this student if different from exam location
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([examinationId, studentId])
  @@index([examinationId])
  @@index([studentId])
}

model SpecialArrangement {
  id              String     @id @default(cuid())
  studentId       String     // Clerk user ID
  examinationId   String
  examination     Examination @relation(fields: [examinationId], references: [id], onDelete: Cascade)
  arrangementType String     // e.g. EXTRA_TIME, SEPARATE_ROOM, READER, SCRIBE, REST_BREAKS
  approvedBy      String?    // Clerk user ID of approver (Registrar / Exam Officer)
  notes           String?    @db.Text
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([examinationId])
  @@index([studentId])
}

// Phase 18: Exam result per student (for AI analysis and sync to ProgrammeModuleGrade)
model ExamResult {
  id             String      @id @default(cuid())
  examinationId  String
  examination    Examination @relation(fields: [examinationId], references: [id], onDelete: Cascade)
  studentId      String      // Clerk user ID
  score          Float?      // Numeric score (e.g. 0-100)
  grade          String?    // Letter or grade string
  feedback       String?    @db.Text
  syncedToGrade  Boolean     @default(false) // When pushed to ProgrammeModuleGrade
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([examinationId, studentId])
  @@index([examinationId])
  @@index([studentId])
}

// ----- Phase 19: Institutional Analytics & BI Snapshots -----
model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportType  String   // retention | equity | financial | cohort | engagement | overall
  data        Json     // Recharts-ready series + insights + recommendations
  generatedAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, reportType])
  @@index([generatedAt])
}

// ----- Phase 20: Intelligent Scheduling & Timetabling -----
// Room: per-tenant, optional school; capacity, type, availability as JSONB.
model Room {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schoolId     String?  // Optional: when schoolsEnabled, room can belong to a school
  school       School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  name         String
  capacity     Int      @default(0)
  type         String   // e.g. LECTURE_HALL, LAB, SEMINAR, OFFICE
  availability Json?    // e.g. { "1": [{ "start": 480, "end": 1020 }], ... } day 1=Mon -> slots in minutes from midnight
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schedules Schedule[]

  @@index([tenantId])
  @@index([schoolId])
}

// Schedule: programme module slot in a term (day_of_week + start/end time, room, lecturer).
model Schedule {
  id                 String   @id @default(cuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  programmeId        String
  programme          Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  moduleId           String   // ProgrammeModule id
  module             ProgrammeModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  roomId             String
  room               Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  lecturerId         String?  // Clerk user ID
  termId             String
  term               AcademicTerm @relation(fields: [termId], references: [id], onDelete: Cascade)
  dayOfWeek          Int      // 0 = Sunday, 1 = Monday, ... 6 = Saturday
  startMinutes       Int      // Minutes from midnight (0–1439)
  endMinutes         Int      // Minutes from midnight (0–1439)
  recurrencePattern  String?  // e.g. WEEKLY, BIWEEKLY; null = weekly default
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId])
  @@index([termId])
  @@index([programmeId])
  @@index([roomId])
  @@index([lecturerId])
}

// ----- Skills graph (with vector embedding for semantic search) -----
// SkillNode + SkillEdge form the skills graph; embedding column uses PGVector.
model SkillNode {
  id          String   @id @default(cuid())
  tenantId    String
  externalId  String?  // Optional external ID (e.g. from SIS)
  name        String
  description String?
  embedding   Unsupported("vector(1536)")? // OpenAI ada-002 / similar 1536-dim
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, externalId])
}

// Optional: edges for skill prerequisites
model SkillEdge {
  id        String   @id @default(cuid())
  tenantId  String
  fromId    String   // SkillNode id
  toId      String   // SkillNode id
  createdAt DateTime @default(now())

  @@unique([tenantId, fromId, toId])
  @@index([tenantId])
}

// ----- Platform finance settings (singleton: one row) -----
// Used on Admin > Finance > Settings. One record; create if missing.
model PlatformFinanceSettings {
  id            String   @id @default(cuid())
  pricingPlans  Json?    // { sis: { amount, currency, period }, lms: {}, hybrid: {} }
  paymentTerms  Json?    // { defaultTerms, dueDays, latePolicy }
  bankDetails   Json?    // { bankName, bban, swift, accountMasked, referenceFormat, instructions }
  taxCompliance Json?    // { taxId, vatNumber, invoicePrefix, nextNumber }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ----- Agentic AI: friction signals, intervention briefs, mastery state -----
// FrictionSignal: raw learning signals (dwell time, quiz errors, huddle activity, etc.)
enum FrictionSignalType {
  DWELL_TIME       // Long time on a page/section
  QUIZ_ERROR       // Wrong or repeated quiz answers
  HUDDLE_ACTIVITY  // Help-seeking or peer interaction
  REPEAT_ATTEMPT   // Re-attempting same content
  SKIP_OR_ABANDON  // Skipped or abandoned section
  OTHER
}

model FrictionSignal {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String            // Clerk user ID
  moduleId  String?           // LMS Module id
  courseId  String?            // LMS Course id
  signalType FrictionSignalType
  payload   Json?              // { durationSeconds?, errorCount?, attempt?, context? }
  createdAt DateTime          @default(now())

  @@index([tenantId, studentId])
  @@index([tenantId, studentId, moduleId])
  @@index([createdAt])
}

// InterventionBrief: agent-generated brief for lecturer (escalation) or in-app action
enum InterventionBriefType {
  MICRO_SCAFFOLD         // In-app hint / micro-scaffold
  ALTERNATIVE_EXPLANATION // Agent suggested alternative explanation
  BRANCHING_PATHWAY      // Suggested branching path
  LECTURER_INTERVENTION  // Brief sent to lecturer for human follow-up
}

enum InterventionBriefStatus {
  PENDING
  SENT
  ACKNOWLEDGED
}

model InterventionBrief {
  id             String                 @id @default(cuid())
  tenantId       String
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId      String
  moduleId       String?
  courseId       String?
  briefType      InterventionBriefType
  content        String                 @db.Text  // JSON or markdown summary
  status         InterventionBriefStatus @default(PENDING)
  createdByAgentAt DateTime             @default(now())
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([tenantId, studentId])
  @@index([tenantId, status])
  @@index([createdByAgentAt])
}

// StudentMasteryState: per-student per-module (and skills graph) state
model StudentMasteryState {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String
  moduleId  String?
  courseId  String?
  stateJson Json?    // { masteryLevel?, skills?: string[], confidence?, lastInterventionAt? }
  updatedAt DateTime @updatedAt

  @@unique([tenantId, studentId, moduleId])
  @@index([tenantId, studentId])
  @@index([tenantId, moduleId])
}

// ----- Phase 7: Social Learning, Live Classrooms, Whiteboard, Attendance -----

enum HuddleStatus {
  ACTIVE
  ENDED
}

model Huddle {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId  String?
  course    Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  moduleId  String?
  title     String
  createdBy String       // Clerk user ID of creator/moderator
  status    HuddleStatus @default(ACTIVE)
  startedAt DateTime     @default(now())
  endedAt   DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  messages HuddleMessage[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([courseId])
}

model HuddleMessage {
  id        String   @id @default(cuid())
  huddleId  String
  huddle    Huddle   @relation(fields: [huddleId], references: [id], onDelete: Cascade)
  authorId  String   // Clerk user ID
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([huddleId])
  @@index([huddleId, createdAt])
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
}

model LiveSession {
  id             String            @id @default(cuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId       String?
  course         Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  title          String
  createdBy      String            // Clerk user ID (lecturer / owner)
  provider       String            // "daily" | "livekit"
  externalRoomId String?           // Room ID from provider
  roomUrl        String?           @db.Text
  status         LiveSessionStatus @default(SCHEDULED)
  startedAt      DateTime?
  endedAt        DateTime?
  metadata       Json?             // Provider-specific config, recording flags, etc.
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  attendanceRecords AttendanceRecord[]
  whiteboardSessions WhiteboardSession[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([courseId])
  @@index([createdBy])
}

model WhiteboardSession {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  liveSessionId   String?
  liveSession     LiveSession?  @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  courseId        String?
  title           String
  createdBy       String        // Clerk user ID
  documentSnapshot Json?        // tldraw document state (shapes, bindings, etc.)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([liveSessionId])
}

model AttendanceRecord {
  id             String       @id @default(cuid())
  liveSessionId  String
  liveSession    LiveSession  @relation(fields: [liveSessionId], references: [id], onDelete: Cascade)
  studentId      String       // Clerk user ID
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?
  engagementScore Int?        // 0-100 derived from WebRTC metadata (presence, audio/video activity)
  metadata       Json?        // Raw WebRTC/participant events for audit
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([liveSessionId, studentId])
  @@index([liveSessionId])
  @@index([studentId])
}

// ----- Phase 11: Student Success, Equity, Wellness & Global Layer -----
model StudentPreference {
  id                    String   @id @default(cuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId             String   // Clerk user ID
  preferredLanguage     String?  // e.g. "en", "es", "ar"
  accessibilitySettings Json?   // { reducedMotion, highContrast, fontSize, screenReader, etc. }
  lowBandwidthMode      Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([tenantId, studentId])
  @@index([tenantId])
  @@index([studentId])
}

enum WellnessNudgeType {
  WELLNESS_CHECKIN
  MOTIVATION
  TIME_MANAGEMENT
  STRESS_RELIEF
  EQUITY_SUPPORT
  OTHER
}

model WellnessLog {
  id        String           @id @default(cuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId String           // Clerk user ID
  nudgeType WellnessNudgeType
  message   String           @db.Text
  response  String?          @db.Text // Student's optional response (e.g. "I'm doing okay")
  createdAt DateTime         @default(now())

  @@index([tenantId, studentId])
  @@index([tenantId, studentId, createdAt])
}

model EquityMetric {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId    String   // Clerk user ID
  firstGen     Boolean  @default(false)  // First-generation student
  lowIncome    Boolean  @default(false)
  neurodiverse Boolean  @default(false)
  caregiver    Boolean  @default(false)  // Primary caregiver responsibilities
  refugeeOrDisplaced Boolean @default(false)
  otherFlags   Json?    // Optional: { "veteran": true, "foster": false, ... } for extensibility
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, studentId])
  @@index([tenantId])
  @@index([studentId])
}

// ----- Phase 13: Finance & Financial Aid (enterprise-ready) -----
enum FinancialAidStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

model FinancialAidApplication {
  id                String              @id @default(cuid())
  tenantId          String
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId         String              // Clerk user ID
  programmeId       String
  programme         Programme           @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  requestedAmount   Decimal             @db.Decimal(12, 2)
  status            FinancialAidStatus  @default(DRAFT)
  submittedAt       DateTime?
  reviewedBy        String?             // Clerk user ID of reviewer
  awardedAmount     Decimal?            @db.Decimal(12, 2)
  decisionDate      DateTime?
  aiRecommendation  Json?               // LLM: { recommendation, confidence, factors, suggestedAmount? }
  decisionLetter    String?             @db.Text
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  awards            FinancialAidAward[]

  @@index([tenantId])
  @@index([tenantId, studentId])
  @@index([tenantId, status])
  @@index([programmeId])
}

model Invoice {
  id                         String        @id @default(cuid())
  tenantId                   String
  tenant                     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId                  String        // Clerk user ID
  amount                     Decimal       @db.Decimal(12, 2)
  dueDate                    DateTime
  status                     InvoiceStatus @default(DRAFT)
  items                      Json          // [{ description, amount, quantity? }]
  stripePaymentLinkId        String?       // Stripe Payment Link or Checkout Session ID
  stripePaymentLinkUrl       String?       @db.Text
  financialAidApplicationId  String?       // Optional: link when invoice is remaining after award
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt

  payments                   Payment[]

  @@index([tenantId])
  @@index([tenantId, studentId])
  @@index([tenantId, status])
  @@index([dueDate])
}

model Payment {
  id             String   @id @default(cuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount         Decimal  @db.Decimal(12, 2)
  method         String   // e.g. "stripe", "bank_transfer", "cash"
  transactionId String?   // Stripe payment intent ID or external reference
  date           DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([invoiceId])
  @@index([transactionId])
}

model FinancialAidAward {
  id            String                 @id @default(cuid())
  applicationId String
  application   FinancialAidApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  awardType     String                 // e.g. "grant", "scholarship", "bursary", "loan"
  amount        Decimal                @db.Decimal(12, 2)
  conditions    String?                @db.Text
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([applicationId])
}

// ----- Phase 14: Configurable Multi-Step Admissions Workflow Engine -----
// Respects traditional university governance: Admissions → Academic Affairs → HoD → Dean → Registry.

enum ProgrammeType {
  CERTIFICATE
  DIPLOMA
  UNDERGRADUATE
  POSTGRADUATE
}

enum AdmissionApplicationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  MORE_INFO_REQUESTED
}

enum ApplicationReviewStatus {
  PENDING
  APPROVED
  REJECTED
  MORE_INFO_REQUESTED
}

// Phase 21: Multi-channel notification engine
enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum AiAssistLevel {
  NONE    // No AI at this step
  SUMMARY // AI summary only (e.g. prior learning, fit)
  FULL    // Full AI assist (AdmissionsAIMatcher, prior learning assessment)
}

model AdmissionWorkflow {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  programmeType  ProgrammeType  // Certificate, Diploma, Undergraduate, Postgraduate
  name           String         // e.g. "Undergraduate admissions"
  steps          Json?          // Snapshot of steps config for builder display; source of truth is WorkflowStep
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  workflowSteps WorkflowStep[]

  @@unique([tenantId, programmeType])
  @@index([tenantId])
}

model WorkflowStep {
  id                String        @id @default(cuid())
  workflowId        String
  workflow          AdmissionWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepOrder         Int           // 0-based order in pipeline
  roleName          String        // e.g. Admissions, Academic Affairs, HoD, Dean, Registry
  department        String?       // Optional: scope to department code/name
  requiredApproval  Boolean       @default(true)
  aiAssistLevel     AiAssistLevel @default(NONE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  applicationReviews ApplicationReview[]
  applicationsAtStep AdmissionApplication[]  // Applications currently at this step

  @@index([workflowId])
  @@index([workflowId, stepOrder])
}

model AdmissionApplication {
  id                   String                     @id @default(cuid())
  tenantId             String
  tenant               Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applicantId          String                     // Clerk user ID
  programmeId          String?                    // Optional: link to Programme (Faculty → Department → Programme)
  programme            Programme?                 @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  programmeType        ProgrammeType              // Drives which workflow is used
  status               AdmissionApplicationStatus @default(DRAFT)
  currentWorkflowStepId String?                   // Current step in the pipeline
  currentWorkflowStep  WorkflowStep?              @relation(fields: [currentWorkflowStepId], references: [id], onDelete: SetNull)
  submittedAt          DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  reviews ApplicationReview[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([applicantId])
  @@index([programmeId])
  @@index([programmeType])
}

model ApplicationReview {
  id          String                 @id @default(cuid())
  applicationId String
  application   AdmissionApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  stepId       String
  step         WorkflowStep          @relation(fields: [stepId], references: [id], onDelete: Cascade)
  reviewerId   String?               // Clerk user ID of reviewer
  status       ApplicationReviewStatus @default(PENDING)
  comments     String?               @db.Text
  aiSummary    String?               @db.Text    // AI-generated summary / prior learning / fit
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([applicationId, stepId])
  @@index([applicationId])
  @@index([stepId])
  @@index([reviewerId])
}

// ----- Phase 21: Multi-Channel Notification Engine -----
// Templates: per-tenant, named, with channel and body_template ({{variable}} placeholders).
model NotificationTemplate {
  id            String              @id @default(cuid())
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String              // e.g. "grade_posted", "appointment_reminder"
  channel       NotificationChannel
  subject       String?             @db.Text  // For email; null for SMS/push/in_app
  bodyTemplate  String              @db.Text  // {{variable}} placeholders
  variables     Json?               // Schema of expected variables for UI: [{ key, label?, required? }]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  notifications Notification[]

  @@unique([tenantId, name, channel])
  @@index([tenantId])
}

// Individual notification record: rendered title/body, status, delivery metadata.
model Notification {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId      String?
  template        NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  tenantId        String
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel         NotificationChannel
  title           String             @db.Text
  body            String             @db.Text
  status          NotificationStatus @default(PENDING)
  sentAt          DateTime?
  deliveryStatus  String?            // Provider-specific: delivered, failed, bounced, etc.
  metadata        Json?              // Provider response, external id, etc.
  readAt          DateTime?          // For in_app: when user marked as read
  createdAt       DateTime           @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([userId, status])
  @@index([createdAt])
}

// Per-user per-tenant per-channel preferences (opt-in/opt-out).
model NotificationPreference {
  id        String              @id @default(cuid())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([tenantId, userId, channel])
  @@index([tenantId])
  @@index([userId])
}

// ----- Phase 23: Library Services & Resource Integration -----
model LibraryResource {
  id               String              @id @default(cuid())
  tenantId         String
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title            String
  author           String?
  isbn             String?
  type             LibraryResourceType // book | article | video | eBook
  url              String?             @db.Text
  accessLevel      LibraryAccessLevel  @default(OPEN)
  availableCopies  Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  readingListItems ReadingListItem[]
  reserves         Reserve[]

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, accessLevel])
}

model ReadingList {
  id           String   @id @default(cuid())
  programmeId  String
  programme    Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  moduleId     String?  // Optional: module-specific list
  module       ProgrammeModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  name         String
  createdBy    String   // Clerk user ID
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items ReadingListItem[]

  @@index([programmeId])
  @@index([moduleId])
}

model ReadingListItem {
  id            String         @id @default(cuid())
  readingListId String
  readingList   ReadingList   @relation(fields: [readingListId], references: [id], onDelete: Cascade)
  resourceId    String
  resource      LibraryResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  required      Boolean        @default(false)
  order         Int           @default(0)
  createdAt     DateTime      @default(now())

  @@unique([readingListId, resourceId])
  @@index([readingListId])
  @@index([resourceId])
}

model Reserve {
  id             String          @id @default(cuid())
  resourceId     String
  resource       LibraryResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  programmeId    String
  programme      Programme      @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  availableFrom  DateTime        @db.Date
  availableTo    DateTime       @db.Date
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([resourceId])
  @@index([programmeId])
  @@index([availableFrom, availableTo])
}

// ----- Phase 24: HR & Faculty Workload Management -----
enum EmploymentStatus {
  FULL_TIME
  PART_TIME
  CONTRACT
  ADJUNCT
  VISITING
}

enum WorkloadType {
  TEACHING
  RESEARCH
  ADMIN
  SERVICE
}

enum FacultyLeaveType {
  ANNUAL
  SICK
  STUDY
  PARENTAL
  UNPAID
  OTHER
}

enum FacultyLeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model FacultyProfile {
  id                  String            @id @default(cuid())
  tenantId            String
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId          String
  schoolId            String?
  school              School?           @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  departmentId        String?
  department          Department?       @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employmentStatus    EmploymentStatus  @default(FULL_TIME)
  hireDate            DateTime          @db.Date
  maxWorkloadHours    Float             @default(0)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  workloadAssignments WorkloadAssignment[]
  leaves              FacultyLeave[]

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([schoolId])
  @@index([departmentId])
}

model WorkloadAssignment {
  id               String           @id @default(cuid())
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  facultyId        String
  faculty          FacultyProfile   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  moduleId         String
  module           ProgrammeModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  workloadType     WorkloadType
  hoursAllocated   Float            @default(0)
  termId           String
  term             AcademicTerm     @relation(fields: [termId], references: [id], onDelete: Cascade)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([tenantId])
  @@index([facultyId])
  @@index([termId])
  @@index([facultyId, termId])
}

model FacultyLeave {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  facultyId   String
  faculty     FacultyProfile     @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  leaveType   FacultyLeaveType
  startDate   DateTime           @db.Date
  endDate     DateTime           @db.Date
  status      FacultyLeaveStatus @default(PENDING)
  approvedBy  String?
  notes       String?            @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([tenantId])
  @@index([facultyId])
  @@index([status])
  @@index([startDate, endDate])
}

// ----- Phase 26: Alumni & Career Services -----
// Phase 26: Alumni/Career events (separate from Phase 28 InstitutionalEvent)
enum EventType {
  alumni_networking
  career_fair
  webinar
}

enum MentorshipStatus {
  PENDING
  ACTIVE
  ENDED
}

enum JobOpportunityType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
  VOLUNTEER
}

model AlumniProfile {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  graduationYear  Int
  degree          String
  currentEmployer String?
  currentRole     String?
  linkedinUrl     String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([graduationYear])
}

model CareerOpportunity {
  id        String               @id @default(cuid())
  tenantId  String
  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  company   String
  location  String?
  type      JobOpportunityType
  postedBy  String                // Clerk user ID
  expiresAt DateTime              @db.Date
  description String?             @db.Text
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([tenantId])
  @@index([postedBy])
  @@index([expiresAt])
  @@index([type])
}

model AlumniMentorship {
  id        String           @id @default(cuid())
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mentorId  String           // Clerk user ID (alumni)
  menteeId  String           // Clerk user ID (student)
  status    MentorshipStatus @default(PENDING)
  startDate DateTime?        @db.Date
  endDate   DateTime?        @db.Date
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([tenantId])
  @@index([mentorId])
  @@index([menteeId])
  @@index([status])
}

model Event {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  date        DateTime   @db.Date
  type        EventType  // alumni_networking | career_fair | webinar
  description String?   @db.Text
  location    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([type])
}

// ----- Phase 28: Institutional Events & Activities Calendar -----
enum InstitutionalEventType {
  meeting
  workshop
  ceremony
  exam
  social
}

enum InstitutionalEventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

model AcademicYearCalendar {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  year     Int      // e.g. 2025
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events InstitutionalEvent[]

  @@unique([tenantId, year])
  @@index([tenantId])
}

model InstitutionalEvent {
  id                      String                   @id @default(cuid())
  tenantId                String
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schoolId                String?
  school                  School?                  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  departmentId            String?
  department              Department?             @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  programmeId             String?
  programme               Programme?               @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  academicYearCalendarId  String?
  academicYearCalendar    AcademicYearCalendar?   @relation(fields: [academicYearCalendarId], references: [id], onDelete: SetNull)
  title                   String
  description             String?                  @db.Text
  startTime               DateTime
  endTime                 DateTime
  type                    InstitutionalEventType  // meeting | workshop | ceremony | exam | social
  createdBy               String                   // Clerk user ID
  status                  InstitutionalEventStatus @default(DRAFT)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([tenantId])
  @@index([tenantId, startTime])
  @@index([departmentId])
  @@index([schoolId])
  @@index([academicYearCalendarId])
}

// ----- Phase 27: AI System-Wide Orchestrator — central intelligence layer -----
// Stores proactive insights and recommendations generated by AISystemOrchestrator.
model SystemInsight {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  insightType      String    // e.g. "student_struggling", "equity_gap", "timetable_optimization", "finance_alert"
  title            String
  description      String    @db.Text
  confidenceScore  Float     // 0–1
  actionLink       String?   @db.Text  // Optional deep link for one-click navigation (e.g. /progress/studentId)
  /** When set, insight was auto-applied (low-risk). When null and actionLink present, flagged for human review. */
  appliedAt        DateTime?
  /** Optional JSON payload for "Apply" (e.g. suggested content, params). */
  actionPayload    Json?
  createdAt        DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, insightType])
  @@index([tenantId, createdAt])
}
