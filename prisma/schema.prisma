// Prisma schema for SILS — Student Information and Learning System
// Database: Neon Postgres with full PGVector extension (vector search)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ----- Extensions (PGVector) -----
// Enable in Neon: CREATE EXTENSION IF NOT EXISTS vector;
// vector(1536) matches OpenAI text-embedding-ada-002 / compatible embeddings.

// ----- Enums -----
enum UserRole {
  OWNER
  ADMIN
  INSTRUCTOR
  LEARNER
  SUPPORT
}

enum DeploymentMode {
  SIS
  LMS
  HYBRID
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

// Onboarding: deployment mode choice during request (SIS, LMS, Hybrid SIS+LMS)
enum OnboardingDeploymentMode {
  SIS
  LMS
  HYBRID
}

enum OnboardingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Platform (super admin) staff roles — who can do what on the admin side
enum PlatformRole {
  PLATFORM_OWNER       // Full control: staff, institutions, onboarding
  PLATFORM_ADMIN       // Institutions + onboarding; cannot manage staff
  ONBOARDING_MANAGER   // Approve/reject onboarding only
  SUPPORT             // Read-only: view institutions and requests
  AUDITOR             // Read-only: audit/compliance view
}

enum PlatformStaffStatus {
  ACTIVE
  SUSPENDED
}

// B2B onboarding request (pending super admin approval)
model OnboardingRequest {
  id               String                    @id @default(cuid())
  deploymentMode   OnboardingDeploymentMode
  institutionName  String
  slug             String                   @unique // subdomain identifier
  contactPerson    String
  contactEmail     String
  phone            String?
  country          String
  website          String?
  approxStudents   Int?
  status           OnboardingRequestStatus  @default(PENDING)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?   @db.Text  // Required when rejecting; explains why request was rejected
  tenantId         String?                  // Set when approved
  tenant           Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // ----- Due diligence / institution profile -----
  addressLine1           String?
  addressLine2           String?
  addressCity            String?
  addressStateRegion     String?
  addressPostalCode      String?
  yearFounded            Int?
  institutionType        String?   // e.g. Public university, Private college, K-12 district
  legalEntityName        String?   // If different from institution name
  taxIdOrRegistrationNumber String?
  accreditationStatus   String?   // Accredited, Not accredited, In progress, Not applicable
  accreditationBody     String?   // Name of accrediting body
  accreditationCertificateUrl String?  // Link to certificate document
  missionOrDescription  String?   @db.Text
  numberOfCampuses      Int?

  // Financial verification (required before approval)
  financialVerifiedAt   DateTime?   // When platform admin verified payment received
  financialVerifiedBy   String?     // Clerk user ID of admin who verified
  quotationSentAt      DateTime?   // When onboarding quotation/invoice was sent to institution
  quotationInvoiceNumber String?   // Assigned when quotation is sent (e.g. SILS-0001)
  invoiceAccessToken   String?     @unique // Token for public invoice URL (sent in quotation email)
  receiptAccessToken   String?     @unique // Token for receipt URL (set when payment verified; email contains link)
  invoiceSnapshot      Json?       // Immutable copy of invoice at send time (request + settings) for reference
  receiptSnapshot      Json?       // Immutable copy of receipt at payment time for reference
  termsAcceptedAt     DateTime?   // When institution accepted terms via quotation link (before approval)

  @@index([status])
  @@index([createdAt])
}

// ----- Tenant (Clerk Organization mapping) -----
model Tenant {
  id              String        @id @default(cuid())
  clerkOrgId      String        @unique // Clerk Organization ID
  name            String
  slug            String        @unique // subdomain or identifier
  deploymentMode  DeploymentMode @default(LMS)
  status          TenantStatus  @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Terms & Conditions: institution must accept before full access
  termsAcceptedAt DateTime?
  // Payment: set when onboarding payment was verified (before or at approval)
  paymentVerifiedAt DateTime?

  // Structured feature flags (preferred over JSON)
  featureFlags    FeatureFlags?
  // Legacy JSON fallback: { sisEnabled, skillsGraphEnabled, pwaEnabled, lowBandwidthEnabled }
  featureFlagsJson Json?

  users           UserTenantRole[]
  courses         Course[]
  calendarEvents  CalendarEvent[]
  onboardingRequests OnboardingRequest[]
}

// ----- Feature flags (per-tenant, structured) -----
model FeatureFlags {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sisEnabled          Boolean  @default(false)
  skillsGraphEnabled  Boolean  @default(false)
  pwaEnabled          Boolean  @default(true)
  lowBandwidthEnabled Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ----- User <-> Tenant (many-to-many with role) -----
model UserTenantRole {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clerkUserId String   // Clerk User ID
  userId      String?  // Optional link to User when synced
  user        User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  role        UserRole
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, clerkUserId])
  @@index([clerkUserId])
  @@index([tenantId])
  @@index([userId])
}

// ----- User (minimal; auth is Clerk) -----
model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String?
  firstName   String?
  lastName    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantRoles UserTenantRole[]
}

// ----- Platform-level admins (super admins; can manage all institutions) -----
model PlatformAdmin {
  id          String              @id @default(cuid())
  clerkUserId String              @unique
  email       String?             // Denormalized for display; synced from Clerk when adding
  role        PlatformRole        @default(PLATFORM_ADMIN)
  status      PlatformStaffStatus @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

// ----- LMS Enums -----
enum CourseMode {
  SYNC   // Synchronous / live
  ASYNC  // Self-paced / asynchronous
}

enum AssignmentType {
  QUIZ
  ESSAY
  PROJECT
  DISCUSSION
  OTHER
}

enum GradebookStatus {
  DRAFT
  PUBLISHED
}

enum CalendarEventType {
  CLASS
  DEADLINE
  EXAM
  OTHER
}

// ----- Course -----
model Course {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  description String?    @db.Text
  createdBy   String?    // Clerk user ID of creator
  mode        CourseMode @default(ASYNC)
  published   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, createdBy])

  modules         Module[]
  gradebookEntries GradebookEntry[]
}

// ----- Module (within a course) -----
model Module {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  order       Int      @default(0)
  contentType String?  // e.g. "text", "video", "embed", "file"
  contentJson  Json?    // Flexible content payload
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId])

  assignments Assignment[]
}

// ----- Assignment (within a module) -----
model Assignment {
  id         String         @id @default(cuid())
  moduleId   String
  module     Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title      String
  type       AssignmentType @default(OTHER)
  dueDate    DateTime?
  rubricJson Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([moduleId])

  submissions Submission[]
}

// ----- Submission (student work for an assignment) -----
model Submission {
  id           String   @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String   // Clerk user ID
  content      String?  @db.Text
  grade        String?  // e.g. "A", "85", or points
  feedback     String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([assignmentId])
  @@index([assignmentId, studentId])
}

// ----- GradebookEntry (per student per course) -----
model GradebookEntry {
  id         String          @id @default(cuid())
  studentId  String          // Clerk user ID
  courseId   String
  course     Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  finalGrade String?         // e.g. "A", "3.2 GPA"
  status     GradebookStatus @default(DRAFT)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([courseId, studentId])
  @@index([courseId])
  @@index([studentId])
}

// ----- CalendarEvent (tenant-level events) -----
model CalendarEvent {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  startTime DateTime
  endTime   DateTime
  type      CalendarEventType @default(OTHER)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([tenantId])
  @@index([tenantId, startTime])
}

// ----- Skills graph (with vector embedding for semantic search) -----
// SkillNode + SkillEdge form the skills graph; embedding column uses PGVector.
model SkillNode {
  id          String   @id @default(cuid())
  tenantId    String
  externalId  String?  // Optional external ID (e.g. from SIS)
  name        String
  description String?
  embedding   Unsupported("vector(1536)")? // OpenAI ada-002 / similar 1536-dim
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, externalId])
}

// Optional: edges for skill prerequisites
model SkillEdge {
  id        String   @id @default(cuid())
  tenantId  String
  fromId    String   // SkillNode id
  toId      String   // SkillNode id
  createdAt DateTime @default(now())

  @@unique([tenantId, fromId, toId])
  @@index([tenantId])
}

// ----- Platform finance settings (singleton: one row) -----
// Used on Admin > Finance > Settings. One record; create if missing.
model PlatformFinanceSettings {
  id            String   @id @default(cuid())
  pricingPlans  Json?    // { sis: { amount, currency, period }, lms: {}, hybrid: {} }
  paymentTerms  Json?    // { defaultTerms, dueDays, latePolicy }
  bankDetails   Json?    // { bankName, bban, swift, accountMasked, referenceFormat, instructions }
  taxCompliance Json?    // { taxId, vatNumber, invoicePrefix, nextNumber }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
